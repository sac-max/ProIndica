{
  "entities": {
    "User": {
      "title": "User",
      "description": "Base user profile for both clients and professionals",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "phoneVerified": { "type": "boolean" },
        "cpf": { "type": "string" },
        "address": { "type": "string" },
        "number": { "type": "string" },
        "city": { "type": "string" },
        "cep": { "type": "string" },
        "state": { "type": "string" },
        "photoURL": { "type": "string" },
        "role": { "type": "string", "enum": ["client", "professional", "admin"] },
        "platform": { "type": "string", "enum": ["web", "ios", "android"] },
        "location": { "type": "object" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "Professional": {
      "title": "Professional",
      "description": "Extended profile for service providers",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "cpf": { "type": "string" },
        "address": { "type": "string" },
        "number": { "type": "string" },
        "city": { "type": "string" },
        "cep": { "type": "string" },
        "state": { "type": "string" },
        "photoURL": { "type": "string" },
        "profession": { "type": "string" },
        "specialization": { "type": "string" },
        "description": { "type": "string" },
        "categories": { "type": "array", "items": { "type": "string" } },
        "experience": { "type": "string" },
        "worksPerformed": { "type": "string" },
        "portfolio": { "type": "array", "items": { "type": "string" } },
        "socialLinks": {
          "type": "object",
          "properties": {
            "website": { "type": "string" },
            "instagram": { "type": "string" },
            "facebook": { "type": "string" },
            "linkedin": { "type": "string" }
          }
        },
        "averagePrice": { "type": "number" },
        "rating": { "type": "number" },
        "jobsCompleted": { "type": "number" },
        "isPremium": { "type": "boolean" },
        "skills": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["uid", "name", "email", "phone", "cpf", "address", "number", "city", "cep", "state", "profession", "specialization", "categories", "experience", "worksPerformed"]
    },
    "Job": {
      "title": "Job",
      "description": "Job posting",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "clientId": { "type": "string" },
        "status": { "type": "string", "enum": ["open", "in-progress", "completed", "cancelled"] },
        "category": { "type": "string" },
        "budget": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "clientId", "status"]
    },
    "Review": {
      "title": "Review",
      "description": "Service review",
      "type": "object",
      "properties": {
        "professionalId": { "type": "string" },
        "clientId": { "type": "string" },
        "rating": { "type": "number" },
        "comment": { "type": "string" },
        "verificationCode": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["professionalId", "clientId", "rating", "verificationCode"]
    },
    "ReviewCode": {
      "title": "ReviewCode",
      "description": "Unique code generated by professional for a client to leave a review",
      "type": "object",
      "properties": {
        "code": { "type": "string" },
        "professionalId": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "used", "expired"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "usedAt": { "type": "string", "format": "date-time" },
        "usedBy": { "type": "string" }
      },
      "required": ["code", "professionalId", "status", "createdAt"]
    },
    "Stat": {
      "title": "Stat",
      "description": "Global statistics and counters",
      "type": "object",
      "properties": {
        "totalAccesses": { "type": "number" },
        "lastUpdated": { "type": "string", "format": "date-time" }
      }
    },
    "PageView": {
      "title": "PageView",
      "description": "Individual page view log",
      "type": "object",
      "properties": {
        "path": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      }
    },
    "Payment": {
      "title": "Payment",
      "description": "Record of a successful transaction",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "currency": { "type": "string" },
        "stripeSessionId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "userEmail": { "type": "string" }
      },
      "required": ["userId", "amount", "stripeSessionId", "timestamp"]
    },
    "Category": {
      "title": "Category",
      "description": "Professional category and its sub-specializations",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "specializations": { "type": "array", "items": { "type": "string" } },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name"]
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "User", "description": "User profiles" },
    "/professionals/{uid}": { "schema": "Professional", "description": "Professional details" },
    "/jobs/{jobId}": { "schema": "Job", "description": "Job postings" },
    "/reviews/{reviewId}": { "schema": "Review", "description": "Service reviews" },
    "/review_codes/{codeId}": { "schema": "ReviewCode", "description": "Codes for validating reviews" },
    "/stats/{statId}": { "schema": "Stat", "description": "Global statistics" },
    "/page_views/{viewId}": { "schema": "PageView", "description": "Page view logs" },
    "/payments/{paymentId}": { "schema": "Payment", "description": "Transaction records" },
    "/categories/{catId}": { "schema": "Category", "description": "Dynamic profession categories" }
  }
}
